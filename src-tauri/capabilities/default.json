{
  "identifier": "default",
  "description": "Capability for the main and output windows",
  "windows": ["main", "output"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-get-all-webviews",
    "core:webview:allow-webview-close",
    "core:window:allow-close",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.semojum.app/*" },
        { "url": "https://storage.googleapis.com/*" }
      ]
    },
    "oauth:allow-start",
    "oauth:allow-cancel",
    "updater:default",
    "process:default"
  ]
}
