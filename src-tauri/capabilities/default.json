{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://api.semojum.app/*" }]
    },
    "oauth:default",
    "updater:default",
    "process:default"
  ]
}
