# 개발: 빈 값 → 상대경로(/api, /oauth2)로 요청되어 vite proxy(api.semojum.app)를 탄다.
# (단, 소셜 로그인은 Tauri 환경 필요 → `bun run tauri:dev`로 실행)
VITE_API_BASE_URL=

# 소셜 로그인 (데스크톱 loopback OAuth).
# kakao: REST API 키 / google: "데스크톱 앱" OAuth Client ID.
VITE_KAKAO_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
# loopback redirect 포트. provider 콘솔에 http://127.0.0.1:<이 포트> 등록 필요.
VITE_OAUTH_PORT=4279
